# NEXT_PUBLIC_* variables are baked into the JS bundle at BUILD time, not
# read at request time. Setting them only in a local .env.local file does
# nothing for a deployed site -- you must also set them in your hosting
# provider's dashboard (Vercel/Netlify project settings -> Environment
# Variables) and then trigger a new build. Forgetting this is the most
# common cause of a deployed frontend silently trying to call
# http://localhost:4000 from a visitor's browser, which shows up as a
# failed request (sometimes reported as a 404 or 504) that only happens in
# production and never locally.

# Must be the full public URL of your deployed backend, no trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:4000

# From Google Cloud Console -> APIs & Services -> Credentials. Also add
# every domain this app is served from (this one + prod) to that OAuth
# client's "Authorized JavaScript origins" -- NOT "Authorized redirect
# URIs", since Google Identity Services' button flow (used here) never
# redirects.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
