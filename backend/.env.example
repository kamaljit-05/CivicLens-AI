# Server
PORT=4000
NODE_ENV=development
# Comma-separated list -- add every origin the frontend is actually served
# from (prod domain, Vercel/Netlify preview URLs, localhost for dev). A
# mismatch here is the #1 cause of requests that silently fail in the
# browser with no useful error.
FRONTEND_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://civiclens:civiclens@localhost:5432/civiclens

# Auth
# Google Cloud Console -> APIs & Services -> Credentials -> your OAuth
# client -> "Authorized JavaScript origins". This app uses Google Identity
# Services' one-tap/button flow, NOT the redirect flow, so origins go under
# "Authorized JavaScript origins", never "Authorized redirect URIs" --
# putting them in the wrong field is the most common cause of Google
# sign-in failing after deploy.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Admin access -- comma-separated Gmail addresses. Only these accounts can
# reach /admin and the /api/admin/* endpoints; this is re-checked on every
# admin request (see src/config/adminEmails.js), not just at login.
ADMIN_EMAILS=kamaljittripathy025@gmail.com

# AI microservice
AI_SERVICE_URL=http://localhost:8000

# News -- powered by Google News' free public RSS feed (see
# backend/src/services/news.service.js), not NewsAPI.org. No key required,
# no daily quota, and unlike NewsAPI.org's free tier, safe to actually use
# in a deployed app rather than localhost-only development.
NEWS_TRUSTED_DOMAINS=thehindu.com,timesofindia.indiatimes.com,indianexpress.com,bbc.com,reuters.com
# Optional -- language/country for Google News' own locale params. Defaults
# shown below are for an Indian English audience; change if not applicable.
NEWS_HL=en-IN
NEWS_GL=IN

# Reverse geocoding (OpenStreetMap Nominatim) -- required by their usage
# policy, put a real app name + contact so requests aren't blocked:
# https://operations.osmfoundation.org/policies/nominatim/
NOMINATIM_USER_AGENT=CivicLensAI/1.0 (you@example.com)

# Duplicate detection tuning
DUPLICATE_POINT_RADIUS_M=100
DUPLICATE_LINEAR_RADIUS_M=500
DUPLICATE_RESOLVED_WINDOW_DAYS=60
DUPLICATE_SIMILARITY_THRESHOLD=0.7

# Object storage (image uploads) — plug in S3/GCS/local disk
UPLOADS_DIR=./uploads
